{
  "files.exclude": {
    "**/*.js": {
      "when": "$(basename).ts"
    },
    "**/*.map": {
      "when": "$(basename).map"
    },
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true
  },
  "editor.rulers": [
    100
  ],
  "workbench.iconTheme": "vscode-great-icons",
  "search.exclude": {
    "**/.venv/": true,
    "**/venv/": true,
    "**/dist/": true,
    "**/.mypy_cache/": true
  },
  "search.useIgnoreFiles": false,
  "editor.renderWhitespace": "all",
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": true,
  "files.insertFinalNewline": true,
  "editor.formatOnPaste": true,
  "editor.minimap.enabled": false,
  "explorer.confirmDelete": false,
  "files.associations": {
    "*.avsc": "json"
  },
  "explorer.confirmDragAndDrop": false,
  "git.confirmSync": false,
  "vsdocker.imageUser": "docker.io/melkerman",
  "liveshare.guestApprovalRequired": true,
  "liveshare.allowGuestDebugControl": true,
  "liveshare.allowGuestTaskControl": true,
  "git.suggestSmartCommit": false,
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "editor.suggestSelection": "first",
  "python.languageServer": "None",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "security.workspace.trust.untrustedFiles": "open",
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook"
  },
  "workbench.editor.revealIfOpen": true,
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[elixir]": {
    "editor.formatOnSave": true
  },
  "[dart]": {
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.rulers": [
      10
    ],
    "editor.selectionHighlight": false,
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.suggestSelection": "first",
    "editor.tabCompletion": "onlySnippets",
    "editor.wordBasedSuggestions": "off"
  },
  "[markdown]": {
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.defaultFormatter": "yzhang.markdown-all-in-one"
  },
  "vsicons.dontShowNewVersionMessage": true,
  "editor.tabCompletion": "on",
  "gitlens.hovers.currentLine.enabled": false,
  "gitlens.autolinks": [
    {
      "url": "https://dev.azure.com/BusinessVenture/Creator%20Studio/_boards/board/t/Station%20-%20Fulfill%20and%20Support/Stories/?workitem=<num>",
      "prefix": "TICKET-"
    }
  ],
  "[python]": {
    "editor.formatOnType": true,
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    },
  },
  "elixirLS.enableTestLenses": true,
  "elixirLS.suggestSpecs": false,
  "emmet.includeLanguages": {
    "phoenix-heex": "html"
  },
  "git.openRepositoryInParentFolders": "always",
  "window.zoomLevel": 1,
  "cursor.cpp.disabledLanguages": [
    "plaintext",
    "markdown",
    "scminput"
  ],
  "cloudcode.duetAI.project": "",
  "extensions.ignoreRecommendations": true,
  "vs-kubernetes": {
    "vs-kubernetes.minikube-show-information-expiration": "2025-08-07T12:32:35.538Z",
    "vs-kubernetes.crd-code-completion": "disabled"
  },
  "githubPullRequests.pullBranch": "never",
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "workbench.colorTheme": "Default Dark Modern",
  "cursor.composer.textSizeScale": 1.15,
  "cursorpyright.analysis.typeCheckingMode": "basic",
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "editor.parameterHints.enabled": false,
  "editor.hover.enabled": false,
  "editor.inlayHints.enabled": "offUnlessPressed"
}
