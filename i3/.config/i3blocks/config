command=~/.local/bin/statusbar/$BLOCK_NAME
separator_block_width=20
markup=pango

[clock]
label=🕑
interval=30
markup=none

[cpu]
interval=15
label=💻
markup=none

[battery]
interval=30
markup=none

[i3volume]
label=
command=~/i3-volume/volume output i3blocks
interval=once
signal=10
color=#b8bb26
separator_block_width=10
markup=pango
